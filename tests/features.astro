fn abs(x: int) -> int {
    if x < 0 {
        0 - x
    } else {
        x
    }
}

fn classify(n: int) -> int {
    match n {
        0 => 0,
        1 => 1,
        _ => 2,
    }
}

fn main() -> int {
    let a = abs(0 - 42);
    print(a);
    let b = classify(1);
    print(b);
    let c = 3 + 4 * 2;
    print(c);
    let flag: bool = true;
    print(flag);
    return 0;
}
